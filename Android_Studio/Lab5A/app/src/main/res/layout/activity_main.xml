<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="10dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="100dp">

    <EditText android:id="@+id/etId" android:hint="ID"
        android:layout_height="wrap_content" android:layout_width="wrap_content"/>
    <EditText android:id="@+id/etName" android:hint="Name"
        android:layout_height="wrap_content" android:layout_width="wrap_content"/>
    <EditText android:id="@+id/etMarks" android:hint="Marks"
        android:layout_height="wrap_content" android:layout_width="wrap_content"/>

    <Button android:id="@+id/btnAdd" android:text="Add"
        android:layout_height="wrap_content" android:layout_width="wrap_content"/>
    <Button android:id="@+id/btnView" android:text="View"
        android:layout_height="wrap_content" android:layout_width="wrap_content"/>
    <Button android:id="@+id/btnUpdate" android:text="Update"
        android:layout_height="wrap_content" android:layout_width="wrap_content"/>
    <Button android:id="@+id/btnDelete" android:text="Delete"
        android:layout_height="wrap_content" android:layout_width="wrap_content"/>

    <TextView android:id="@+id/tvResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:hint="Result"/>
</LinearLayout>